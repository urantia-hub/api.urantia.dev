{
  "name": "urantia-dev-api",
  "module": "src/index.ts",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "bun --hot src/index.ts",
    "start": "bun src/index.ts",
    "seed": "bun scripts/seed.ts",
    "seed:entities": "bun scripts/seed-entities.ts",
    "db:generate": "bunx drizzle-kit generate",
    "db:migrate": "bunx drizzle-kit migrate",
    "db:push": "bunx drizzle-kit push",
    "db:studio": "bunx drizzle-kit studio",
    "lint": "bunx biome check src/",
    "format": "bunx biome format --write src/",
    "typecheck": "bunx tsc --noEmit",
    "generate-manifest": "bun scripts/generate-audio-manifest.ts",
    "generate-embeddings": "bun scripts/generate-embeddings.ts",
    "create-hnsw-index": "bun scripts/create-hnsw-index.ts",
    "deploy": "wrangler deploy",
    "test": "bun test"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.7",
    "@cloudflare/workers-types": "^4.20260317.1",
    "@types/bun": "latest",
    "drizzle-kit": "^0.31.9",
    "wrangler": "^4.73.0"
  },
  "peerDependencies": {
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.78.0",
    "@hono/mcp": "^0.2.4",
    "@hono/swagger-ui": "^0.5.3",
    "@hono/zod-openapi": "^1.2.2",
    "@logtail/edge": "^0.5.8",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "drizzle-orm": "^0.45.1",
    "hono": "^4.12.8",
    "openai": "^6.29.0",
    "postgres": "^3.4.8",
    "workers-og": "^0.0.27",
    "zod": "^4.3.6"
  }
}
