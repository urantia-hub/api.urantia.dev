# Supabase
DATABASE_URL=""

# OpenAI
OPENAI_API_KEY=""

# BetterStack
BETTERSTACK_SOURCE_TOKEN=""

# Data source paths (optional — defaults assume urantia-data-sources repo as sibling)
# See DATA_PIPELINE.md for details
# DATA_DIR=""                 # Papers JSON directory (default: ../../urantia-data-sources/data/json/eng)
# AUDIO_MANIFEST=""           # Audio manifest path (default: ../data/audio-manifest.json)
# SEED_ENTITIES_PATH=""       # Entity seed JSON (default: ../data/entities/seed-entities.json)
# MP3_DIR=""                  # MP3 directory for manifest generation (default: ../../urantia-data-sources/data/audio/eng)
# TOPIC_INDEX_DIR=""          # Urantiapedia topic index (default: ../../urantiapedia/input/txt/topic-index-en)
